Options -Indexes
RewriteEngine On
# ─── حماية الملفات الحساسة ──────────────────────────────────────────
<FilesMatch "^(\.env|\.env\..*|config\.php)$">
  Require all denied
</FilesMatch>
# ─── HTTPS Redirect ──────────────────────────────────────────────
RewriteCond %{HTTP:X-Forwarded-Proto} =http
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ─── Static assets & admin pass-through ─────────────────────────
RewriteCond %{REQUEST_URI} ^/(assets|admin|includes|lang|layouts|pages|supabase)/
RewriteRule ^ - [L]

RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# ─── Single post:  /ar/news/some-slug  or  /en/leaks/some-slug ───
RewriteRule ^(ar|en)/(news|formations|upgrades|leaks)/([^/]+)/?$ /post.php?locale=$1&category=$2&slug=$3 [L,QSA]

# ─── Locale homepage: /ar/ or /en/ ──────────────────────────────
RewriteRule ^(ar|en)/?$ /$1/index.php [L,QSA]

# ─── Category indexes: /ar/news/ ────────────────────────────────
RewriteRule ^(ar|en)/(news|formations|upgrades|leaks)/?$ /$1/$2/index.php [L,QSA]

# ─── Contact: /ar/contact/ ──────────────────────────────────────
RewriteRule ^(ar|en)/contact/?$ /$1/contact/index.php [L,QSA]

# ─── Admin clean URLs ───────────────────────────────────────────
RewriteRule ^admin/?$ /admin/dashboard.php [L,QSA]

# ─── 404 fallback ───────────────────────────────────────────────
ErrorDocument 404 /pages/404.php
