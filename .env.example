# ── PostgreSQL (Supabase) ─────────────────────────────────────────
# من Supabase: Settings → Database → Connection string → URI
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres

# ── MySQL (للتطوير المحلي فقط، يُتجاهل عند وجود DATABASE_URL) ───
DB_HOST=localhost
DB_PORT=3306
DB_NAME=sg_efootball
DB_USER=root
DB_PASS=

# ── الموقع ───────────────────────────────────────────────────────
SITE_URL=https://your-app.up.railway.app
SITE_NAME=Saif Jabbar
CREATOR_NAME=Saif Jabbar

# ── الأدمن ───────────────────────────────────────────────────────
LOCAL_AUTH=false
ADMIN_EMAIL=admin@sg-efootball.com
ADMIN_PASSWORD=SG@Admin2026
