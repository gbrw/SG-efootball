# ══════════════════════════════════════════════════════════════════
#  متغيرات البيئة — Vercel + Supabase (PostgreSQL)
#  على Vercel: Dashboard → Project → Settings → Environment Variables
#  محلياً:     انسخ هذا الملف إلى .env وعدّل القيم
# ══════════════════════════════════════════════════════════════════

# ── Supabase — قاعدة البيانات ──────────────────────────────────────
# خذ هذا من: Supabase Dashboard → Project Settings → Database → Connection String
# استخدم Transaction Pooler (port 6543) للبيئات الـ serverless مثل Vercel
DATABASE_URL=postgresql://postgres.XXXX:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres

# ── PostgreSQL للتطوير المحلي فقط (تُتجاهل إذا كان DATABASE_URL مضبوطاً) ──
DB_HOST=localhost
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASS=

# ── Supabase Storage — رفع الصور ──────────────────────────────────
# خذ هذه من: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://XXXX.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...
SUPABASE_BUCKET=uploads

# ── الموقع ───────────────────────────────────────────────────────
SITE_URL=https://your-project.vercel.app
SITE_NAME=Saif Jabbar
CREATOR_NAME=Saif Jabbar

# ── الأدمن ───────────────────────────────────────────────────────
LOCAL_AUTH=false
ADMIN_EMAIL=admin@sg-efootball.com
ADMIN_PASSWORD=SG@Admin2026
# APP_SECRET: سلسلة عشوائية طويلة لتوقيع الكوكيز
APP_SECRET=REPLACE_WITH_RANDOM_SECRET
