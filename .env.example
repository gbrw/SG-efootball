# ══════════════════════════════════════════════════════════════════
#  متغيرات البيئة — Railway + MySQL
#  على Railway: Dashboard → Variables → أضف كل متغير أدناه
# ══════════════════════════════════════════════════════════════════

# ── MySQL (Railway يولّد MYSQL_URL تلقائياً عند إضافة MySQL plugin) ──
# لا تحتاج إضافته يدوياً — Railway يضيفه تلقائياً
# MYSQL_URL=mysql://user:password@host:port/database

# ── MySQL للتطوير المحلي فقط ──────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=sg_efootball
DB_USER=root
DB_PASS=

# ── الموقع ───────────────────────────────────────────────────────
SITE_URL=https://sg-efootball-production.up.railway.app
SITE_NAME=Saif Jabbar
CREATOR_NAME=Saif Jabbar

# ── الأدمن ───────────────────────────────────────────────────────
LOCAL_AUTH=false
ADMIN_EMAIL=admin@sg-efootball.com
ADMIN_PASSWORD=SG@Admin2026
