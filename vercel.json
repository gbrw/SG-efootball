{
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.6.2"
    }
  },
  "routes": [
    {
      "src": "^/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "^/images/(.*)",
      "dest": "/images/$1"
    },
    {
      "src": "^/(.*\\.(ico|png|jpg|jpeg|svg|webp|gif|css|js|woff2?|ttf|map|txt|xml))$",
      "dest": "/$1"
    },
    {
      "src": "^/(.*)",
      "dest": "/api/index.php"
    }
  ]
}
